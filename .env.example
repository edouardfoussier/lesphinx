# Mistral API
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest
INTENT_CLASSIFIER_MODEL=mistral-small-latest

# ElevenLabs TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=5egO01tkUjEzu7xSSE8M
ELEVENLABS_MODEL=eleven_flash_v2_5

# Game engine mode: "hybrid" (deterministic + LLM layers) or "full_llm" (single LLM call)
GAME_ENGINE_MODE=hybrid

# Voice Agent (real-time voice via WebSocket)
VOICE_AGENT_ENABLED=false
VOICE_AGENT_MODE=streaming
VOICE_AGENT_STREAMING_TTS=true

# PersonaPlex via fal.ai (only for VOICE_AGENT_MODE=personaplex)
FAL_API_KEY=
PERSONAPLEX_VOICE=NATM0

# Amazon Bedrock (AI opponents) — use bearer token OR IAM keys
AWS_BEARER_TOKEN_BEDROCK=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
