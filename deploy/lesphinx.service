[Unit]
Description=LeSphinx Game Server
After=network.target

[Service]
Type=simple
User=edouardfoussier
WorkingDirectory=/home/edouardfoussier/lesphinx
EnvironmentFile=/home/edouardfoussier/lesphinx/.env
ExecStart=/home/edouardfoussier/lesphinx/.venv/bin/uvicorn lesphinx.main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
