[Unit]
Description=LeSphinx Game Server
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/lesphinx
EnvironmentFile=/opt/lesphinx/.env
ExecStart=/opt/lesphinx/.venv/bin/uvicorn lesphinx.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
